# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=cs2user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cs2db

# SteamAPIs.com (https://steamapis.com)
# Zarejestruj się na https://steamapis.com — plan darmowy: 500 req/miesiąc.
# Przy domyślnym STEAM_POLL_INTERVAL_SECONDS=6000 (100 min) zużyjesz ~14 req/dzień ≈ 420/miesiąc.
STEAMAPIS_API_KEY=

# Skinport API (https://skinport.com/api)
# Utwórz aplikację na: https://skinport.com/account/api
SKINPORT_CLIENT_ID=
SKINPORT_CLIENT_SECRET=

# CSFloat API (https://csfloat.com/api)
# Klucz API z ustawień konta: https://csfloat.com/profile
CSFLOAT_API_KEY=

# Interwał pobierania danych dla SteamAPIs (sekundy).
# Domyślnie 6000 s (ok. 100 min) = ~14 req/dzień przy planie darmowym steamapis.com.
# NIE ustawiaj niżej niż 5400 (16/dzień) jeśli korzystasz z planu darmowego!
STEAM_POLL_INTERVAL_SECONDS=6000

# Interwał pobierania danych dla darmowych/nielimitowanych API (Skinport, CSFloat) (sekundy).
# Domyślnie 300 s (5 min) dla szybszego wykrywania okazji.
GENERAL_POLL_INTERVAL_SECONDS=300

# Interwał między cyklami analizy (sekundy, domyślnie 60 s)
ANALYSIS_INTERVAL_SECONDS=60

# Minimalny realny spread netto (po prowizjach) do wygenerowania alertu arbitrażowego (%)
ARBITRAGE_MIN_SPREAD_PCT=5.0

# Discord (potrzebne dopiero przy uruchamianiu discord_bot)
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# Interwał sprawdzania nowych alertów przez bota (sekundy, domyślnie 30 s)
ALERT_POLL_INTERVAL_SECONDS=30
