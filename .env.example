# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=cs2user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cs2db

# Skinport API (https://skinport.com/api)
# Utwórz aplikację na: https://skinport.com/account/api
SKINPORT_CLIENT_ID=
SKINPORT_CLIENT_SECRET=

# CSFloat API (https://csfloat.com/api)
# Klucz API z ustawień konta: https://csfloat.com/profile
CSFLOAT_API_KEY=

# Interwał między cyklami pobierania danych (sekundy, domyślnie 300 = 5 min)
POLL_INTERVAL_SECONDS=300

# Interwał między cyklami analizy (sekundy, domyślnie 60 s)
ANALYSIS_INTERVAL_SECONDS=60

# Minimalny realny spread netto (po prowizjach) do wygenerowania alertu arbitrażowego (%)
ARBITRAGE_MIN_SPREAD_PCT=5.0

# Discord (potrzebne dopiero przy uruchamianiu discord_bot)
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
